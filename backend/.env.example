# ============================================================
#  Backend .env — FinTrack API Server
#  Copy file ini ke .env dan isi sesuai konfigurasi kamu
#  JANGAN commit file .env ke Git!
# ============================================================

# Server
PORT=8080
ENV=production

# Security — gunakan string acak minimal 32 karakter
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# Telegram Bot (untuk bot-gateway container)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_URL=https://YOUR_API_DOMAIN.COM/api/v1/telegram/webhook
TELEGRAM_SECRET_TOKEN=YOUR_TELEGRAM_WEBHOOK_SECRET_TOKEN_HERE

# PostgreSQL — format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://fintrack:YOUR_POSTGRES_PASSWORD_HERE@postgres:5432/fintrack?sslmode=disable
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE

# CORS — whitelist domain frontend (comma-separated)
ALLOWED_ORIGINS=https://YOUR_APP.vercel.app,http://localhost:3000

# ─────────────────────────────────────────────────────────────
#  Inter-Service Communication (Gateway Architecture)
# ─────────────────────────────────────────────────────────────

# API key protecting /internal/v1/* endpoints on FinTrack API
# Generate: openssl rand -hex 32
GATEWAY_API_KEY=YOUR_GATEWAY_API_KEY_HERE

# URL of FinTrack API (used by bot-gateway to call internal endpoints)
# In docker-compose: http://fintrack-api:8080
# Local dev: http://localhost:8080
FINTRACK_API_URL=http://fintrack-api:8080

# Home Server service URL and API key
# In docker-compose: http://home-server:8090
# Leave blank to disable home server integration
HOME_SERVER_URL=http://home-server:8090
HOME_SERVER_API_KEY=YOUR_HOME_SERVER_API_KEY_HERE

# n8n workflow automation
# In docker-compose (services/): http://n8n:5678
# Leave blank to disable n8n integration
N8N_URL=http://n8n:5678
N8N_API_KEY=YOUR_N8N_API_KEY_HERE
