# ============================================================
#  Backend .env — FinTrack API Server
#  Copy file ini ke .env dan isi sesuai konfigurasi kamu
#  JANGAN commit file .env ke Git!
# ============================================================

# Server
PORT=8080
ENV=production

# Security — gunakan string acak minimal 32 karakter
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_URL=https://YOUR_API_DOMAIN.COM/api/v1/telegram/webhook
TELEGRAM_SECRET_TOKEN=YOUR_TELEGRAM_WEBHOOK_SECRET_TOKEN_HERE

# Firebase
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
GOOGLE_APPLICATION_CREDENTIALS=/app/configs/firebase-credentials.json

# CORS — whitelist domain frontend Vercel (comma-separated)
# Contoh: https://fintrack.vercel.app,https://fintrack-git-main.vercel.app,*.vercel.app
# Untuk development: tambahkan http://localhost:3000
ALLOWED_ORIGINS=https://YOUR_APP.vercel.app,http://localhost:3000
