# ============================================================
#  Backend .env — FinTrack API Server
#  Copy file ini ke .env dan isi sesuai konfigurasi kamu
#  JANGAN commit file .env ke Git!
# ============================================================

# Server
PORT=8080
ENV=production

# Security — gunakan string acak minimal 32 karakter
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_URL=https://YOUR_API_DOMAIN.COM/api/v1/telegram/webhook
TELEGRAM_SECRET_TOKEN=YOUR_TELEGRAM_WEBHOOK_SECRET_TOKEN_HERE

# PostgreSQL — format: postgres://user:password@host:port/dbname?sslmode=disable
# Jika menggunakan docker-compose, host = nama service postgres ("postgres")
# Jika menggunakan managed DB (Supabase, Neon, Railway), salin connection string dari dashboard
DATABASE_URL=postgres://fintrack:YOUR_POSTGRES_PASSWORD_HERE@postgres:5432/fintrack?sslmode=disable

# Password PostgreSQL — harus sama dengan POSTGRES_PASSWORD di docker-compose.yml
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE

# CORS — whitelist domain frontend Vercel (comma-separated)
# Contoh: https://fintrack.vercel.app,https://fintrack-git-main.vercel.app,*.vercel.app
# Untuk development: tambahkan http://localhost:3000
ALLOWED_ORIGINS=https://YOUR_APP.vercel.app,http://localhost:3000
