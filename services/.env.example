# Services — environment variables
# Copy ke .env di folder services/ lalu isi

# ── n8n ──────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=YOUR_N8N_PASSWORD_HERE

# Webhook URL — sesuaikan dengan domain/Cloudflare tunnel kamu
N8N_WEBHOOK_URL=https://n8n.yourdomain.com

# API key untuk bot-gateway memanggil n8n API
# Buat di: n8n UI → Settings → API → Create API Key
N8N_API_KEY=YOUR_N8N_API_KEY_HERE
