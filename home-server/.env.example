# Home Server — environment variables
# Copy this file to .env and fill in values

# Port to listen on (default: 8090)
PORT=8090

# API key for X-API-Key header — keep this secret!
# Use: openssl rand -hex 32
API_KEY=YOUR_HOME_SERVER_API_KEY_HERE

# Comma-separated list of allowed IPs for dangerous endpoints (/pc/*, /scripts/run)
# Supports CIDR notation, e.g: 192.168.1.0/24,172.16.0.1
# Leave empty to allow all IPs (not recommended for production)
ALLOWED_IPS=127.0.0.1,172.16.0.0/12

# Directory containing whitelisted scripts (default: ./scripts)
SCRIPTS_DIR=./scripts
